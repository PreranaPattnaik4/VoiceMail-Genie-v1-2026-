# Environment Variables for VoiceMail Genie
# Set this to your Google Gemini API Key. Do not expose this key to the browser.
GEMINI_API_KEY=

# Client-side Firebase Configuration (optional for external deployment)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

